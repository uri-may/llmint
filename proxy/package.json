{
  "name": "@llmint/proxy",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:watch": "vitest",
    "test:integration": "vitest run test/integration --no-file-parallelism",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ed25519": "2.2.3",
    "@noble/hashes": "1.7.1",
    "hono": "4.7.6",
    "viem": "2.47.1",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@hono/node-server": "1.14.1",
    "@types/node": "22.15.29",
    "tsx": "4.19.4",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
